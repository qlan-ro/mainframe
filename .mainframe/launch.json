{
  "version": "1",
  "configurations": [
    {
      "name": "Setup Worktree",
      "runtimeExecutable": "./scripts/setup-ports.sh",
      "runtimeArgs": [],
      "port": null,
      "url": null
    },
    {
      "name": "Core Daemon",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@qlan-ro/mainframe-core", "run", "dev"],
      "port": "${DAEMON_PORT:-31416}",
      "url": null,
      "env": {
        "DAEMON_PORT": "${DAEMON_PORT:-31416}",
        "MAINFRAME_DATA_DIR": "${MAINFRAME_DATA_DIR:-~/.mainframe_dev}"
      }
    },
    {
      "name": "Preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@qlan-ro/mainframe-ui", "run", "dev"],
      "port": "${VITE_PORT:-5174}",
      "url": null,
      "preview": false,
      "env": {
        "VITE_PORT": "${VITE_PORT:-5174}",
        "VITE_DAEMON_HTTP_PORT": "${DAEMON_PORT:-31416}",
        "VITE_DAEMON_WS_PORT": "${DAEMON_PORT:-31416}",
        "MAINFRAME_DATA_DIR": "${MAINFRAME_DATA_DIR:-~/.mainframe_dev}"
      }
    },
    {
      "name": "Dev Tauri",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@qlan-ro/mainframe-app-tauri", "run", "tauri:dev"],
      "port": "${VITE_PORT:-5174}",
      "url": null,
      "preview": false,
      "env": {
        "VITE_PORT": "${VITE_PORT:-5174}",
        "DAEMON_PORT": "${DAEMON_PORT:-31416}",
        "MAINFRAME_EXTERNAL_DAEMON": "1",
        "MAINFRAME_DATA_DIR": "${MAINFRAME_DATA_DIR:-~/.mainframe_dev}"
      }
    },
    {
      "name": "Dev Electron",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev:electron"],
      "port": "${VITE_PORT:-5174}",
      "url": null,
      "preview": false,
      "env": {
        "VITE_PORT": "${VITE_PORT:-5174}",
        "DAEMON_PORT": "31415",
        "VITE_DAEMON_HTTP_PORT": "31415",
        "VITE_DAEMON_WS_PORT": "31415",
        "MAINFRAME_EXTERNAL_DAEMON": "1",
        "MAINFRAME_DATA_DIR": "${MAINFRAME_DATA_DIR:-~/.mainframe}"
      }
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "./scripts/expo-start.sh",
      "runtimeArgs": [],
      "port": 8081,
      "url": null,
      "preview": false,
      "env": {
        "MAINFRAME_API_URL": "http://localhost:${DAEMON_PORT:-31416}"
      }
    }
  ]
}
