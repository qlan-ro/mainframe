{
  "name": "mainframe",
  "version": "2.0.0-rc.13",
  "private": true,
  "description": "AI-native development environment for orchestrating agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qlan-ro/mainframe.git"
  },
  "homepage": "https://github.com/qlan-ro/mainframe#readme",
  "bugs": {
    "url": "https://github.com/qlan-ro/mainframe/issues"
  },
  "scripts": {
    "dev:core": "pnpm --filter @qlan-ro/mainframe-core run dev",
    "build": "pnpm -r run build",
    "build:types": "pnpm --filter @qlan-ro/mainframe-types run build",
    "build:core": "pnpm --filter @qlan-ro/mainframe-core run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r --filter=!@qlan-ro/mainframe-e2e run test",
    "test:e2e": "pnpm --filter @qlan-ro/mainframe-e2e test",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/ripgrep",
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "tar": ">=7.5.7",
      "@qlan-ro/mainframe-types": "workspace:*"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ],
    "packages/core-rs/**/*.rs": [
      "rustfmt --edition 2024"
    ]
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=8.0.0"
  }
}
