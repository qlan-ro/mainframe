# Real Node binaries are NOT committed — the CI packaging pipeline downloads them
# per target triple from https://nodejs.org/dist/<version>/ and places them here.
# (see docs/architecture/2026-06-24-host-bridge-plan3-infra-todos.md TODO #1)
#
# The files below ARE committed as zero-byte placeholders so that `cargo check`
# passes on every dev/CI platform without requiring the real binaries.
# The packaging pipeline replaces them with the real binaries before `tauri build`.
node-*

# Placeholder exceptions — force-tracked zero-byte stand-ins for cargo check.
!node-aarch64-apple-darwin
!node-x86_64-apple-darwin
!node-x86_64-unknown-linux-gnu
!node-aarch64-unknown-linux-gnu
!node-x86_64-pc-windows-msvc.exe
