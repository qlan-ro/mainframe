{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capabilities for the main Mainframe window — least-privilege.",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" },
        { "url": "mailto:*" },
        { "url": "tel:*" },
        { "url": "slack://*" },
        { "url": "vscode://*" },
        { "url": "vscode-insiders://*" },
        { "url": "cursor://*" },
        { "url": "jetbrains://*" },
        { "url": "idea://*" },
        { "url": "zed://*" },
        { "url": "figma://*" },
        { "url": "linear://*" },
        { "url": "notion://*" },
        { "url": "discord://*" }
      ]
    },
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "updater:default",
    "core:webview:allow-set-webview-zoom"
  ]
}
