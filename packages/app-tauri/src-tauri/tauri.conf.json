{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mainframe",
  "identifier": "ro.qlan.mainframe",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Mainframe",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 30 },
        "backgroundColor": "#e9e7e2"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:31500 ws://localhost:31500; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob:; object-src blob:"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/node"],
    "resources": {
      "resources/daemon/daemon.cjs": "daemon/daemon.cjs",
      "resources/ripgrep/rg": "ripgrep/rg",
      "resources/lsp/typescript-language-server": "lsp/typescript-language-server",
      "resources/lsp/pyright": "lsp/pyright"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": ["https://github.com/qlan-ro/mainframe/releases/latest/download/latest.json"],
      "pubkey": "TODO_PLAN3_INFRA_REPLACE_WITH_TAURI_SIGNER_PUBLIC_KEY"
    }
  }
}
