{
  "name": "@qlan-ro/mainframe-core",
  "version": "0.4.0",
  "description": "Mainframe daemon — session lifecycle, agent process management, and metadata storage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qlan-ro/mainframe.git",
    "directory": "packages/core"
  },
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./messages": "./dist/messages/index.js"
  },
  "bin": {
    "mainframe-daemon": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts | pino-pretty --config ../../pino-pretty.config.cjs",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pair": "node dist/index.js pair",
    "status": "node dist/index.js status"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.83",
    "@qlan-ro/mainframe-types": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "express": "^5.0.0",
    "nanoid": "^5.1.7",
    "pino": "^10.3.1",
    "pyright": "^1.1.408",
    "qrcode-terminal": "^0.12.0",
    "simple-git": "^3.33.0",
    "typescript-language-server": "^5.1.3",
    "vscode-jsonrpc": "^8.2.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.1.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
