{
  "name": "@qlan-ro/mainframe-desktop",
  "version": "0.16.0",
  "description": "Mainframe desktop app — Electron/React frontend for orchestrating AI agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qlan-ro/mainframe.git",
    "directory": "packages/desktop"
  },
  "author": "Mainframe Contributors",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev | pino-pretty --config ../../pino-pretty.config.cjs",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "electron-vite build && node scripts/bundle-daemon.mjs",
    "clean": "rm -rf out dist",
    "start": "electron-vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:playwright": "playwright test -c playwright-ct.config.ts",
    "package": "electron-rebuild -o node-pty && electron-builder",
    "postinstall": "node scripts/fix-pty-permissions.mjs"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.19",
    "@assistant-ui/react-markdown": "^0.12.6",
    "@monaco-editor/react": "^4.7.0",
    "@qlan-ro/mainframe-core": "workspace:*",
    "@qlan-ro/mainframe-types": "workspace:*",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "diff": "^8.0.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "monaco-languageclient": "^10.7.0",
    "nanoid": "^5.1.7",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.5",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.qlan-ro.mainframe",
    "productName": "Mainframe",
    "icon": "resources/icon",
    "files": [
      {
        "from": "out",
        "to": "out",
        "filter": [
          "**/*"
        ]
      },
      "resources/icon*",
      "resources/favicon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/daemon.cjs",
        "to": "daemon.cjs"
      },
      {
        "from": "../../node_modules/better-sqlite3",
        "to": "node_modules/better-sqlite3",
        "filter": [
          "**/*",
          "!**/*.md"
        ]
      },
      {
        "from": "../../node_modules/bindings",
        "to": "node_modules/bindings"
      },
      {
        "from": "../../node_modules/file-uri-to-path",
        "to": "node_modules/file-uri-to-path"
      },
      {
        "from": "../../node_modules/typescript-language-server",
        "to": "node_modules/typescript-language-server",
        "filter": [
          "**/*",
          "!**/*.md"
        ]
      },
      {
        "from": "../../node_modules/pyright",
        "to": "node_modules/pyright",
        "filter": [
          "**/*",
          "!**/*.md"
        ]
      },
      {
        "from": "../../node_modules/@vscode/ripgrep",
        "to": "node_modules/@vscode/ripgrep",
        "filter": [
          "**/*",
          "!**/*.md"
        ]
      },
      {
        "from": "../../node_modules/node-pty",
        "to": "node_modules/node-pty",
        "filter": [
          "**/*",
          "!**/*.md"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "NSAppleMusicUsageDescription": null,
        "NSAudioCaptureUsageDescription": null,
        "NSBluetoothAlwaysUsageDescription": null,
        "NSBluetoothPeripheralUsageDescription": null,
        "NSCameraUsageDescription": null,
        "NSMicrophoneUsageDescription": null
      }
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
