{
  "name": "PR auto-review",
  "description": "When a pull request is opened, ask the agent to run the codex review slash command against it.",
  "scope": "global",
  "definition": {
    "triggers": [{ "id": "trigger-pr-opened", "kind": "webhook", "hookId": "github-pr-opened" }],
    "steps": [
      {
        "id": "ask-codex-review",
        "kind": "ask_agent",
        "prompt": [
          "/codex-review ",
          { "token": { "stepId": "trigger", "output": "payload", "field": "pull_request.html_url" } }
        ]
      }
    ]
  }
}
