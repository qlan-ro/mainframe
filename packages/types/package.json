{
  "name": "@qlan-ro/mainframe-types",
  "version": "0.15.1",
  "description": "Shared TypeScript types for Mainframe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qlan-ro/mainframe.git",
    "directory": "packages/types"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "pino": "^10.3.1",
    "typescript": "^6.0.3"
  }
}
